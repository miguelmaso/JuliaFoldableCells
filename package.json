{
  "name": "juliafoldablecells",
  "publisher": "MiguelMas",
  "license": "MIT",
  "displayName": "Julia Foldable Cells",
  "description": "Enable folding cells in Julia files based on markdown comments",
  "keywords": [
    "julia",
    "folding",
    "cells"
  ],
  "icon": "img/logo.png",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Visualization",
    "Notebooks",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:julia"
  ],
  "extensionDependencies": [
    "julialang.language-julia"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/miguelmaso/JuliaFoldableCells.git"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
